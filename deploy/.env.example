# ── 必填 ──────────────────────────────────────────────────────────────
# 你的網域(DNS A 記錄需已指向本機公網 IP)與 TLS 通知信箱
DOMAIN=lab.example.com
TLS_EMAIL=you@example.com

# 平台管理員帳號(每次啟動會確保存在;改密碼=改這裡再重啟)
VELXIO_ADMIN_EMAIL=admin@example.com
VELXIO_ADMIN_PASSWORD=change-me-to-something-long

# AI 上游(OpenAI 相容端點)— 平台的成本來源
VELXIO_OPENAI_BASE_URL=https://your-relay.example.com/v1
VELXIO_OPENAI_API_KEY=sk-...

# CORS 用的正式站網址(與 DOMAIN 一致,含 https://)
FRONTEND_URL=https://lab.example.com

# ── 選填(其餘營運參數請一律在 /admin 的「平台設定」UI 調整)──────────
# 學生預設週額度種子值(UI 儲存後以 UI 為準)
#VELXIO_DEFAULT_WEEKLY_TOKENS=2000000

# 建置期:prebuilt/qemu/ 沒有 .so 檔時才需要
# (免費個人金鑰:https://velxio.dev/license/signup)
#VELXIO_LICENSE_KEY=vlx_personal_...
